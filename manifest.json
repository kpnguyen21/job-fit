{
  "manifest_version": 3,
  "name": "Universal Job-Fit + Micro Tailor",
  "version": "0.1.0",
  "description": "Analyze any tech job posting and micro-tailor resume bullets with a VS Code-style drawer.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "Universal Job-Fit + Micro Tailor"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/sidebar/sidebar.html",
        "content/sidebar/sidebar.css",
        "content/sidebar/sidebar.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}